{
  "name": "capacitor-updater-server",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Self-hosted OTA update server for Capacitor apps",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "better-auth:db:migrate": "bun scripts/migrate-auth.mjs",
    "app:db:generate": "drizzle-kit generate",
    "app:db:migrate": "drizzle-kit migrate",
    "migrate": "bun run better-auth:db:migrate && bun run app:db:generate && bun run app:db:migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@base-ui/react": "^1.3.0",
    "@elysiajs/swagger": "^1.3.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@scalar/nextjs-api-reference": "^0.10.5",
    "@sinclair/typebox": "^0.34.48",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.24",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.9",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "postgres": "^3.4.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
